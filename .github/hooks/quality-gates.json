{
    "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/hook-schema.json",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "editFiles|createFile|writeFile|create_file|str_replace_editor",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/hooks/scripts/quality-gate.mjs"
                    }
                ]
            }
        ]
    }
}