{
    "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/hook-schema.json",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "runCommand|terminal|executeCommand|bash|run_terminal_command",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/hooks/scripts/safety-guard.mjs"
                    }
                ]
            }
        ]
    }
}